{
  "name": "@asd14/eslint-plugin",
  "version": "3.1.0",
  "description": "ESLint rules for overly fidgety namers",
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asd-xiv/eslint-plugin.git"
  },
  "author": {
    "name": "Andrei Dumitrescu",
    "url": "https://github.com/andreidmt"
  },
  "files": [
    "/dist",
    "SKILL.md"
  ],
  "keywords": [
    "eslint",
    "eslint-plugin"
  ],
  "nx": {
    "projectType": "library",
    "tags": [
      "type:library",
      "target:node"
    ]
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "----UTIL": "",
    "prepare": "git config --local core.hooksPath .githooks",
    "format": "eslint --fix .",
    "----BUNDLE": "",
    "build:code": "swc src -d dist --ignore '**/*.test.ts' --ignore '**/*.estest.ts' --strip-leading-paths",
    "build:types": "tsc --declaration --emitDeclarationOnly --project ./.tsconfig/code.json",
    "prebuild": "rm -rf dist/* node_modules/.tmp/*.tsbuildinfo",
    "build": "npm run build:code && npm run build:types",
    "----LINT": "",
    "lint": "eslint --quiet .",
    "typecheck:code": "tsc --noEmit --project ./.tsconfig/code.json",
    "typecheck:config": "tsc --noEmit --project ./.tsconfig/config.json",
    "typecheck:tests": "tsc --noEmit --project ./.tsconfig/tests.json",
    "typecheck": "npm run typecheck:code && npm run typecheck:config && npm run typecheck:tests",
    "----TEST": "",
    "test": "TSX_TSCONFIG_PATH=.tsconfig/tests.json node --import tsx --test 'src/**/*.test.ts' 'src/**/*.estest.ts'",
    "coverage": "c8 --100 --exclude='src/**/*.test.ts' --exclude='src/**/*.estest.ts' npm run test",
    "----PUBLISH": "",
    "release": "semantic-release"
  },
  "dependencies": {
    "acorn": "^8.16.0"
  },
  "devDependencies": {
    "@asd14/eslint-config": "^15.2.0",
    "@asd14/prettier-config": "^1.2.0",
    "@asd14/ts-config": "^1.3.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "c8": "^11.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "eslint": "^9 || ^10"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
