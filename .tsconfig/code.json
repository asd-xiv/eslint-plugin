{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "rootDir": "../src",
    "outDir": "../dist",
    "tsBuildInfoFile": "../node_modules/.tmp/tsconfig.code.tsbuildinfo"
  },
  "include": ["../src"],
  "exclude": [
    "../src/**/*.test.ts",
    "../src/**/*.estest.ts",
    "../node_modules",
    "../dist",
    "../coverage"
  ]
}
